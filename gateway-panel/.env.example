APP_NAME=OneShield
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_HOST=oneshieldx.com
APP_VERSION=1.0.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.oneshieldx.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_CONNECTION=cache

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── OneShield Configuration ────────────────────────────────────────────────
# Plugin versions (used by auto-update endpoint)
ONESHIELD_CONNECT_VERSION=1.0.0
ONESHIELD_PAYGATES_VERSION=1.0.0

# Plugin download URLs (storage path or external URL)
ONESHIELD_CONNECT_DOWNLOAD_URL=storage/plugins/oneshield-connect.zip
ONESHIELD_PAYGATES_DOWNLOAD_URL=storage/plugins/oneshield-paygates.zip

# CORS — comma-separated list of allowed money site domains
# Use * for development only; set explicit domains in production
ONESHIELD_CORS_ORIGINS=*

# Rate limiting (requests per minute)
ONESHIELD_RATE_LIMIT_API=100
ONESHIELD_RATE_LIMIT_WEBHOOK=200

# HMAC signature max age in seconds (replay attack prevention)
ONESHIELD_HMAC_MAX_AGE=300

# Circuit breaker settings
ONESHIELD_CB_THRESHOLD=5
ONESHIELD_CB_RESET_AFTER=30

# Redis cache TTL for active sites list (seconds)
ONESHIELD_CACHE_SITES_TTL=60

# Checkout Session (checkout_id mechanism)
# Set to true to replace sensitive query params on iframe URL with a short-lived checkout_id
CHECKOUT_ID_ENABLED=false
# Checkout session TTL in minutes (default: 30)
CHECKOUT_ID_TTL_MINUTES=30
